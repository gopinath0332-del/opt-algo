[Unit]
Description=Delta Exchange Options Short Straddle Trading Bot
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/opt-algo
ExecStart=/home/pi/opt-algo/venv/bin/python main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
