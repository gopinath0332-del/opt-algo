# Delta Exchange Options API Configuration
# Get your API keys from: https://testnet.delta.exchange/app/account/manageapikeys

# --- API Credentials (Separate account for options) ---
DELTA_API_KEY=your_options_api_key_here
DELTA_API_SECRET=your_options_api_secret_here

# --- Environment ---
# Testnet (for paper trading):
#   DELTA_ENVIRONMENT=testnet
#   DELTA_BASE_URL=https://cdn-ind.testnet.deltaex.org
#
# Production (for live trading):
#   DELTA_ENVIRONMENT=production
#   DELTA_BASE_URL=https://api.india.delta.exchange

DELTA_ENVIRONMENT=testnet
DELTA_BASE_URL=https://cdn-ind.testnet.deltaex.org

# --- Discord Notifications ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1525431440387473529/PcwMVswECJfA1PrDFXep7sorL9GamsNvAgykzAUvwICXgWxLLHp3cihSZkT4DHSxpL4F
DISCORD_ENABLED=true

# Discord Error Notifications (Optional - separate webhook for errors)
# If not set, errors will be sent to the main DISCORD_WEBHOOK_URL
DISCORD_ERROR_WEBHOOK_URL=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/options.log
LOG_MAX_BYTES=524288000
LOG_BACKUP_COUNT=5

# --- Order Placement Kill-Switch ---
# true  → orders execute on the exchange
# false → bot runs in signal/alert mode only (no real orders)
ENABLE_ORDER_PLACEMENT=false
